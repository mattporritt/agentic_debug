{
  "name": "mattp/agentic-debug",
  "description": "moodle_debug MCP server skeleton with mocked debug backend",
  "type": "project",
  "require": {
    "php": "^8.4",
    "mcp/sdk": "^0.2",
    "opis/json-schema": "^2.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "MoodleDebug\\": "src/moodle_debug/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MoodleDebug\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/moodle-debug",
    "bin/moodle-debug-server"
  ]
}
